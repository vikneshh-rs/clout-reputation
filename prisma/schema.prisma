datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ==========================================
// ENUMS
// ==========================================

enum UserRole {
  SUPER_ADMIN
  REP
}

enum Industry {
  RESTAURANT
  CAFE
  SALON
  RESORT
  HOTEL
  CLINIC
  GYM
  SPA
  RETAIL_STORE
  OTHER
}

enum BusinessStatus {
  ACTIVE
  SUSPENDED
  EXPIRED
}

enum QRStatus {
  UNASSIGNED
  ASSIGNED
  DAMAGED
  REPLACED
  INACTIVE
}

enum CallbackStatus {
  PENDING
  CONTACTED
  RESOLVED
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum SubscriptionPlan {
  TRIAL
  BASIC
  PRO
}

// ==========================================
// MODELS
// ==========================================

model User {
  id                 String          @id @default(uuid())
  name               String
  email              String?         @unique
  username           String          @unique
  passwordHash       String
  role               UserRole        @default(REP)
  isActive           Boolean         @default(true)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  
  // Relations
  qrAssignments      QRInventory[]   @relation("RepAssignments")
  assignmentLogs     AssignmentLog[]
  qrBatches          QRBatch[]
  createdBusinesses  Business[]      @relation("RepCreatedBusinesses")
}

model Business {
  id              String         @id @default(uuid())
  name            String         @unique // Unique Business Name for login
  slug            String         @unique // Unique URL slug
  businessCode    String         @unique // System-generated unique Business Code (e.g. CR-000001)
  passwordHash    String         // Direct password credential for Business Dashboard
  industry        Industry       @default(OTHER)
  logoUrl         String?
  googleReviewUrl String?
  phone           String?
  address         String?
  isActive        Boolean        @default(true)
  status          BusinessStatus @default(ACTIVE)
  deletedAt       DateTime?
  enableGoogleReviewRedirect Boolean @default(true)
  enableManagerCallback      Boolean @default(true)
  
  // REP Onboarding Tracking
  createdByRepId  String?
  createdByRep    User?          @relation("RepCreatedBusinesses", fields: [createdByRepId], references: [id], onDelete: SetNull)

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  // Relations
  reviews         Review[]
  subscriptions   Subscription[]
  qrScans         QRScan[]
  qrInventory     QRInventory[]
  assignmentLogs  AssignmentLog[]

  @@index([createdByRepId])
  @@index([createdAt])
}

model Review {
  id                 String           @id @default(uuid())
  rating             Int              // Overall score: 1 to 5
  comment            String?          // Customer comments
  customerName       String?          // Recovery customer name
  customerPhone      String?          // Recovery customer phone
  requestCallback    Boolean          @default(false)
  callbackStatus     CallbackStatus   @default(PENDING)
  redirectedToGoogle Boolean          @default(false)
  googleCtaViewed    Boolean          @default(false)
  googleCtaClicked   Boolean          @default(false)
  createdAt          DateTime         @default(now())
  
  // Relations
  businessId         String
  business           Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  callbackRequest    CallbackRequest?

  @@index([businessId])
  @@index([createdAt])
  @@index([googleCtaClicked])
}

model CallbackRequest {
  id           String         @id @default(uuid())
  reviewId     String         @unique
  customerName String
  phoneNumber  String
  status       CallbackStatus @default(PENDING)
  createdAt    DateTime       @default(now())

  // Relations
  review       Review         @relation(fields: [reviewId], references: [id], onDelete: Cascade)
}

model Subscription {
  id           String             @id @default(uuid())
  businessId   String
  plan         SubscriptionPlan   @default(TRIAL)
  status       SubscriptionStatus @default(ACTIVE)
  startDate    DateTime           @default(now())
  endDate      DateTime
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  // Relations
  business     Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([status])
}

model ActivityLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id") // References User ID or Business ID
  action     String
  entityType String?  @map("entity_type")
  entityId   String?  @map("entity_id")
  metadata   String?
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("activity_logs")
  @@index([userId])
  @@index([createdAt])
}

model QRScan {
  id           String      @id @default(uuid())
  businessId   String
  qrCode       String
  userAgent    String?
  scannedAt    DateTime    @default(now())
  createdAt    DateTime    @default(now())

  // Relations
  business     Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([qrCode])
}

model QRInventory {
  id                 String      @id @default(uuid())
  qrCode             String      @unique
  status             QRStatus    @default(UNASSIGNED)
  assignedBusinessId String?
  assignedBy         String?
  assignedAt         DateTime?
  replacementQrId    String?     @unique
  createdAt          DateTime    @default(now())

  // Relations
  business           Business?   @relation(fields: [assignedBusinessId], references: [id], onDelete: SetNull)
  rep                User?       @relation("RepAssignments", fields: [assignedBy], references: [id], onDelete: SetNull)
  replacementQr      QRInventory? @relation("ReplacementHistory", fields: [replacementQrId], references: [id])
  replacedQr         QRInventory? @relation("ReplacementHistory")
  logs               AssignmentLog[]

  @@index([assignedBusinessId])
  @@index([assignedBy])
  @@index([status])
}

model AssignmentLog {
  id            String      @id @default(uuid())
  qrInventoryId String
  businessId    String
  assignedBy    String
  action        String      // "ASSIGNED", "REPLACED", "UNASSIGNED"
  createdAt     DateTime    @default(now())

  // Relations
  qrInventory   QRInventory @relation(fields: [qrInventoryId], references: [id], onDelete: Cascade)
  business      Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  rep           User        @relation(fields: [assignedBy], references: [id], onDelete: Cascade)

  @@index([qrInventoryId])
  @@index([businessId])
  @@index([assignedBy])
  @@index([createdAt])
}

model QRBatch {
  id          String   @id @default(uuid())
  batchName   String
  startSerial String
  endSerial   String
  quantity    Int
  generatedBy String
  generatedAt DateTime @default(now())

  creator     User     @relation(fields: [generatedBy], references: [id], onDelete: Cascade)
}
