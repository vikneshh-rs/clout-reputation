datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ==========================================
// ENUMS
// ==========================================

enum UserRole {
  SUPER_ADMIN
  REP
}

enum Industry {
  RESTAURANT
  CAFE
  SALON
  RESORT
  HOTEL
  CLINIC
  GYM
  SPA
  RETAIL_STORE
  OTHER
}

enum BusinessStatus {
  PENDING
  ACTIVE
  INACTIVE
}

enum QRStatus {
  ACTIVE
  ARCHIVED
}

enum QRAssetStatus {
  FREE
  ASSIGNED
}


enum CallbackStatus {
  PENDING
  CONTACTED
  RESOLVED
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum SubscriptionPlan {
  TRIAL
  BASIC
  PRO
}

// ==========================================
// MODELS
// ==========================================

model User {
  id                 String          @id @default(uuid())
  name               String
  email              String?         @unique
  username           String          @unique
  passwordHash       String
  role               UserRole        @default(REP)
  isActive           Boolean         @default(true)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  
  // Relations
  qrAssets           QRAsset[]       @relation("RepAssignments")
  qrHistory          QRHistory[]
  qrBatches          QRBatch[]
  createdBusinesses  Business[]      @relation("RepCreatedBusinesses")
  resolvedRecoveryRequests RecoveryRequest[] @relation("RecoveryResolver")
}

model Business {
  id              String         @id @default(uuid())
  name            String         @unique // Unique Business Name for login
  slug            String         @unique // Unique URL slug
  businessCode    String         @unique // System-generated unique Business Code (e.g. CR-000001)
  passwordHash    String         // Direct password credential for Business Dashboard
  industry        Industry       @default(OTHER)
  logoUrl         String?
  googleReviewUrl String?
  phone           String?
  address         String?
  description     String?
  contactPerson   String?
  category        String?
  website         String?
  googleMapsUrl   String?
  isActive        Boolean        @default(true)
  status          BusinessStatus @default(PENDING)
  deletedAt       DateTime?
  enableGoogleReviewRedirect Boolean @default(true)
  enableManagerCallback      Boolean @default(true)
  whatsappNumber             String?
  
  // REP Onboarding Tracking
  createdByRepId  String?
  createdByRep    User?          @relation("RepCreatedBusinesses", fields: [createdByRepId], references: [id], onDelete: SetNull)

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  // Relations
  reviews         Review[]
  subscriptions   Subscription[]
  qrScans         QRScan[]
  notificationJobs NotificationJob[]
  notificationSettings BusinessNotificationSettings?
  
  assignedQrAssetId String?  @unique @map("assigned_qr_asset_id")
  assignedQrAsset   QRAsset? @relation("ActiveQrAsset", fields: [assignedQrAssetId], references: [id], onDelete: SetNull)

  qrAssets        QRAsset[] @relation("QrAssetBusiness")
  qrHistory       QRHistory[]
  recoveryRequests RecoveryRequest[]
  funnelEvents    FunnelEvent[]

  @@index([createdByRepId])
  @@index([createdAt])
}

model Review {
  id                 String           @id @default(uuid())
  rating             Int              // Overall score: 1 to 5
  comment            String?          // Customer comments
  customerName       String?          // Recovery customer name
  customerPhone      String?          // Recovery customer phone
  requestCallback    Boolean          @default(false)
  callbackStatus     CallbackStatus   @default(PENDING)
  redirectedToGoogle Boolean          @default(false)
  googleCtaViewed    Boolean          @default(false)
  googleCtaClicked   Boolean          @default(false)
  sentiment          String?          // Positive, Neutral, Negative
  themes             String?          // Comma-separated theme list
  createdAt          DateTime         @default(now())
  
  // Relations
  businessId         String
  business           Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  callbackRequest    CallbackRequest?
  recoveryRequest    RecoveryRequest?
  notificationJobs   NotificationJob[]

  @@index([businessId])
  @@index([createdAt])
  @@index([googleCtaClicked])
}

model CallbackRequest {
  id           String         @id @default(uuid())
  reviewId     String         @unique
  customerName String
  phoneNumber  String
  status       CallbackStatus @default(PENDING)
  createdAt    DateTime       @default(now())

  // Relations
  review       Review         @relation(fields: [reviewId], references: [id], onDelete: Cascade)
}

model Subscription {
  id           String             @id @default(uuid())
  businessId   String
  plan         SubscriptionPlan   @default(TRIAL)
  status       SubscriptionStatus @default(ACTIVE)
  startDate    DateTime           @default(now())
  endDate      DateTime
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  // Relations
  business     Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([status])
}

model ActivityLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id") // References User ID or Business ID
  action     String
  entityType String?  @map("entity_type")
  entityId   String?  @map("entity_id")
  metadata   String?
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("activity_logs")
  @@index([userId])
  @@index([createdAt])
}

model QRScan {
  id           String      @id @default(uuid())
  businessId   String
  qrCode       String
  userAgent    String?
  scannedAt    DateTime    @default(now())
  createdAt    DateTime    @default(now())

  // Relations
  business     Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([qrCode])
}

model QRAsset {
  id                 String          @id @default(uuid())
  qrCode             String          @unique @map("qr_code")
  status             QRAssetStatus   @default(FREE)
  assignedBusinessId String?         @map("assigned_business_id")
  assignedDate       DateTime?       @map("assigned_date")
  revokedDate        DateTime?       @map("revoked_date")
  assignedBy         String?         @map("assigned_by")
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")

  // Relations
  business           Business?       @relation("QrAssetBusiness", fields: [assignedBusinessId], references: [id], onDelete: SetNull)
  rep                User?           @relation("RepAssignments", fields: [assignedBy], references: [id], onDelete: SetNull)
  activeBusiness     Business?       @relation("ActiveQrAsset")
  history            QRHistory[]

  @@index([assignedBusinessId])
  @@index([assignedBy])
  @@index([status])
  @@map("qr_assets")
}

model QRHistory {
  id         String    @id @default(uuid())
  qrAssetId  String    @map("qr_asset_id")
  businessId String?   @map("business_id")
  assignedBy String?   @map("assigned_by")
  assignedAt DateTime  @default(now()) @map("assigned_at")
  revokedAt  DateTime? @map("revoked_at")

  // Relations
  qrAsset    QRAsset   @relation(fields: [qrAssetId], references: [id], onDelete: Cascade)
  business   Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)
  rep        User?     @relation(fields: [assignedBy], references: [id], onDelete: SetNull)

  @@index([qrAssetId])
  @@index([businessId])
  @@index([assignedBy])
  @@map("qr_history")
}

model QRBatch {
  id          String   @id @default(uuid())
  batchName   String
  startSerial String
  endSerial   String
  quantity    Int
  generatedBy String
  generatedAt DateTime @default(now())

  creator     User     @relation(fields: [generatedBy], references: [id], onDelete: Cascade)
}

// ==========================================
// RECOVERY & FUNNEL INTELLIGENCE
// ==========================================

enum RecoveryStatus {
  NEW
  CONTACTED
  RESOLVED
  CLOSED
}

enum RecoveryPriority {
  LOW
  MEDIUM
  HIGH
}

model RecoveryRequest {
  id                String           @id @default(uuid())
  businessId        String
  reviewId          String           @unique
  customerName      String
  whatsappNumber    String
  rating            Int
  feedback          String?
  callbackRequested Boolean        @default(false)
  status            RecoveryStatus   @default(NEW)
  priority          RecoveryPriority @default(MEDIUM)
  internalNotes     String?
  resolvedById      String?
  resolvedAt        DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  business          Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  review            Review           @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  resolvedBy        User?            @relation("RecoveryResolver", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([status])
  @@index([priority])
  @@index([createdAt])
}

enum FunnelStage {
  SCAN
  START
  SUBMIT
  REDIRECT
}

model FunnelEvent {
  id              String      @id @default(uuid())
  businessId      String
  stage           FunnelStage
  timestamp       DateTime    @default(now())
  userAgent       String?
  deviceType      String?
  qrAssetCode     String?
  reviewSessionId String

  business        Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([stage])
  @@index([timestamp])
}

enum NotificationStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
  PERMANENTLY_FAILED
}

enum NotificationProvider {
  TWILIO
  META
  RESEND
  SMTP
}

enum NotificationType {
  WHATSAPP
  EMAIL
  SMS
}

enum NotificationEvent {
  NEGATIVE_REVIEW
  POSITIVE_REVIEW
  DAILY_SUMMARY
  WEEKLY_REPORT
}

model NotificationJob {
  id                String               @id @default(uuid())
  status            NotificationStatus   @default(PENDING)
  retryCount        Int                  @default(0)
  notificationType  NotificationType
  eventType         NotificationEvent
  provider          NotificationProvider
  recipient         String
  payload           Json                 // Holds serializable JSON with review/business details
  scheduledFor      DateTime?
  processedAt       DateTime?
  providerMessageId String?
  errorMessage      String?
  
  // Operational Timestamps & Metrics
  queuedAt          DateTime             @default(now())
  startedAt         DateTime?
  completedAt       DateTime?
  processingTimeMs  Int?
  
  // Provider Response Details
  providerStatus    String?
  providerResponse  Json?
  
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  
  // Relations
  reviewId          String?
  review            Review?              @relation(fields: [reviewId], references: [id], onDelete: SetNull)
  businessId        String
  business          Business             @relation(fields: [businessId], references: [id], onDelete: Cascade)
  logs              NotificationLog[]

  @@unique([reviewId, eventType, notificationType])
  @@index([status])
  @@index([businessId])
  @@index([reviewId])
}

model NotificationLog {
  id                 String               @id @default(uuid())
  jobId              String
  job                NotificationJob      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  provider           NotificationProvider
  attemptNumber      Int
  previousStatus     NotificationStatus
  newStatus          NotificationStatus
  providerResponse   Json?
  errorMessage       String?
  timestamp          DateTime             @default(now())
  
  // Dispatch Audit Trail Details
  eventType          NotificationEvent
  notificationType   NotificationType
  processingDuration Int?
}

model BusinessNotificationSettings {
  id                    String   @id @default(uuid())
  businessId            String   @unique
  business              Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  negativeReviewEnabled Boolean  @default(true)
  positiveReviewEnabled Boolean  @default(false)
  dailySummaryEnabled   Boolean  @default(false)
  weeklySummaryEnabled  Boolean  @default(false)
  whatsappEnabled       Boolean  @default(true)
  emailEnabled          Boolean  @default(false)
  smsEnabled            Boolean  @default(false)
  quietHoursStart       String?  // format: "HH:MM" e.g. "22:00"
  quietHoursEnd         String?  // format: "HH:MM" e.g. "08:00"
  timezone              String   @default("UTC")
}

